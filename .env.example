# Obrigatorias para gerar data/latest.json
PLANE_API_TOKEN=
PLANE_WORKSPACE_SLUG=
PLANE_PROJECT_IDS=
ANTHROPIC_API_KEY=

# Anthropic — insights (1 chamada por execução do script)
# Modelo padrão no código: claude-haiku-4-5 (mais barato que Sonnet). Defina aqui para sobrescrever.
# Ex.: claude-sonnet-4-20250514 se precisar de mais qualidade.
ANTHROPIC_MODEL=
# Limite de tokens de saída (default 768 no código se vazio). Entre 256 e 4096.
ANTHROPIC_MAX_TOKENS=
# Opcional no Actions: secrets ANTHROPIC_MODEL e ANTHROPIC_MAX_TOKENS (se não existirem, usa o default do código).

# Opcionais para bloco de OKR e Stripe
STRIPE_SECRET_KEY=
BASELINE_MRR=0
API_IMPLEMENTATIONS_COUNT=6
PLANE_OKR_CYCLE_ID=
PLANE_OKR_MODULE_IDS=

# ── Progresso do projeto / sprint (GitHub) ─────────────────────────────────────
# No GitHub Actions: use estes nomes em Settings → Secrets (prefixo GITHUB_ é reservado no GitHub).
# O workflow .github/workflows/update.yml repassa *_GITHUB_PRODUCT para o script.
# PAT com permissão de leitura em issues (e, se Project v2, em projects do owner).
# Alternativa local: GITHUB_TOKEN= (mesmo valor) se preferir um único nome no .env.
TOKEN_GITHUB_PRODUCT=

# Login de usuário ou organização GitHub (org do Project v2 ou dono do repo no Modo B).
OWNER_GITHUB_PRODUCT=

# Exemplo org + Project v2 (#2): Bros-Digital-Solutions
# OWNER_GITHUB_PRODUCT=Bros-Digital-Solutions
# PROJECT_NUMBER_GITHUB_PRODUCT=2
# OWNER_TYPE_GITHUB_PRODUCT=organization
# Se a API retornar "Resource not accessible by personal access token": o PAT precisa de leitura em
# Projects da organização (fine-grained → Organization permissions → Projects → Read + autorizar na org)
# ou escopo read:project (classic); complete SSO na org se for obrigatório.

# Modo A — GitHub Project v2 (recomendado): número do project (ex: 3). Inclui todas as issues do board.
# Deixe em branco para usar o Modo B (issues por label + repo).
PROJECT_NUMBER_GITHUB_PRODUCT=

# Tipo do owner para o Project v2: "organization" ou "user" (auto-detectado se omitido).
# OWNER_TYPE_GITHUB_PRODUCT=organization

# Modo B — Somente issues por label: nome do repositório.
# Necessário se PROJECT_NUMBER_GITHUB_PRODUCT não estiver definido.
REPO_GITHUB_PRODUCT=

# Label: usado apenas no Modo B (API REST do repo). No Modo A (Project v2) o escopo é o board inteiro — esta variável é ignorada.
# Modo B: se LABEL_GITHUB_PRODUCT não existir no .env, default = Produto. Para não filtrar: LABEL_GITHUB_PRODUCT=
# LABEL_GITHUB_PRODUCT=

# ── Sprint (GitHub Project v2) ────────────────────────────────────────────────
# Com sprint atual definido (env ou auto-sprint), o script filtra pelo campo de iteração
# em vez da semana de calendário. Exige Modo A. O título deve bater com a iteração no GitHub.
# Exemplo BeeMessage: SPRINT_CURRENT_GITHUB_PRODUCT=S2 Abril · SPRINT_PREVIOUS_GITHUB_PRODUCT=S1 Abril
SPRINT_FIELD_NAME_GITHUB_PRODUCT=Sprint
SPRINT_CURRENT_GITHUB_PRODUCT=
SPRINT_PREVIOUS_GITHUB_PRODUCT=
# 1 (default): se CURRENT ou PREVIOUS estiver vazio, o script lê o campo Iteration no Project e
# preenche pela data de hoje (UTC) e pela iteração terminada imediatamente antes. 0 = desliga.
SPRINT_AUTO_GITHUB_PRODUCT=1

# Valores de Status que mapeiam para cada card (separados por vírgula, case-insensitive).
# Defaults no código já incluem PT-BR (Backlog, A fazer, Em andamento, Concluído, etc.).
STATUS_PLANNED_GITHUB_PRODUCT=
STATUS_IN_PROGRESS_GITHUB_PRODUCT=
STATUS_DONE_GITHUB_PRODUCT=

# ── Prioridade por labels (dados no JSON; UI do sprint pode omitir) ───────────
# A prioridade é derivada automaticamente dos nomes de labels em cada issue.
# Heurística embutida reconhece padrões comuns: urgent/urgente/P0, high/alta/P1,
# medium/média/P2, low/baixa/P3 (case-insensitive).
# Use as variáveis abaixo para sobrescrever com os nomes exatos de labels do seu repo.
# Deixe em branco para usar a heurística padrão.
# PRIORITY_URGENTE_GITHUB_PRODUCT=urgent,urgente,crítico,P0
# PRIORITY_ALTA_GITHUB_PRODUCT=high,alta,P1
# PRIORITY_MEDIA_GITHUB_PRODUCT=medium,média,media,P2
# PRIORITY_BAIXA_GITHUB_PRODUCT=low,baixa,P3
